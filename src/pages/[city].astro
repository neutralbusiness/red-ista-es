---
import Layout from "../layouts/Layout.astro";
import { NETWORK, SERVICES, FAQ_BASE } from "../lib/network.ts";
import { getCollection, type CollectionEntry } from "astro:content";

/* ──────────────────────────────────────────────────────────
   Interfaces — definimos aquí el shape v2 del JSON por ciudad.
   ────────────────────────────────────────────────────────── */
interface TrustChip { icon: string; text: string; }
interface ProcessStep { title: string; body: string; }
interface CommonIssue { title: string; body: string; }
interface WhyUsItem { title: string; body: string; }
interface Testimonial { name: string; neighborhood?: string; car?: string; body: string; rating?: number; }
interface FaqItem { q: string; a: string; }

interface TenantConfig {
  active: boolean;
  businessName: string;
  nif?: string;
  ownerName?: string;
  ownerEmail?: string;
  phone: string;
  phoneDisplay: string;
  whatsapp: string;
  email: string;
  addressStreet: string;
  addressPostalCode?: string;
  lat?: number;
  lng?: number;
  gbpUrl?: string;
  hours?: string;
}

interface CityContent {
  slug: string;
  name: string;
  province: string;
  ccaa: string;
  population?: number;
  lat?: number;
  lng?: number;
  metaTitle: string;
  metaDescription: string;
  heroImage?: string;
  heroSubtitle: string;
  trustChips?: TrustChip[];
  introLocal: string;
  servicesIntro: string;
  servicesOverrides?: Record<string, string>;
  processIntro?: string;
  processSteps?: ProcessStep[];
  commonIssuesIntro?: string;
  commonIssues?: CommonIssue[];
  whyUs: WhyUsItem[];
  testimonialsIntro?: string;
  testimonials?: Testimonial[];
  zoneText: string;
  zoneNeighborhoods?: string[];
  zoneAccessRoutes?: string[];
  faqLocal: FaqItem[];
  closingHeadline?: string;
  closingCta: string;
  tenant?: TenantConfig;
}

export async function getStaticPaths() {
  const mods = import.meta.glob<{ default: CityContent }>("../content/cities/*.json", { eager: true });
  const cities = Object.values(mods).map(m => m.default);
  return cities.map(c => ({
    params: { city: c.slug },
    props: { city: c },
  }));
}

const { city } = Astro.props as { city: CityContent };
const canonical = `https://${city.slug}.${NETWORK.domain}/`;
// Últimas 3 entradas del blog visibles en este subdominio (ciudad o globales)
type BlogPost = CollectionEntry<"blog">;
const _allBlog = await getCollection("blog");
const latestPosts: BlogPost[] = _allBlog
  .filter((p) => {
    const parts = p.id.split("/");
    if (parts.length === 1) return true;
    return parts[0] === city.slug;
  })
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
function _postUrl(id: string): string {
  return `/blog/${id.split("/").pop()}/`;
}
function _fmtDate(d: Date): string {
  return d.toLocaleDateString("es-ES", { day: "2-digit", month: "short", year: "numeric" });
}
// Hero image: override por ciudad si lo hay (subido desde panel), si no el global de la red.
const heroImage = city.heroImage || NETWORK.heroImage;

/* ──────────────────────────────────────────────────────────
   Tenant resolution: si el subdominio está contratado por un
   taller real, sus datos sobreescriben los del NETWORK central.
   Vacante por defecto → 641 16 17 71 / info@redtalleres.es.
   ────────────────────────────────────────────────────────── */
const t = city.tenant && city.tenant.active ? city.tenant : null;
const phone = t?.phone ?? NETWORK.phone;
const phoneDisplay = t?.phoneDisplay ?? NETWORK.phoneDisplay;
const whatsapp = t?.whatsapp ?? NETWORK.whatsapp;
const email = t?.email ?? NETWORK.email;
const businessName = t?.businessName ?? `${NETWORK.brand} · ${city.name}`;
const hours = t?.hours ?? "Lunes a Sábado · 08:00–20:00";
const addrStreet = t?.addressStreet;
const addrPostal = t?.addressPostalCode;
const geoLat = t?.lat ?? city.lat;
const geoLng = t?.lng ?? city.lng;
const gbpUrl = t?.gbpUrl;

/* Mapeo trust-chip (por keyword del texto) → SVG minimal-stroke navy.
   El JSON de la IA viene con icon="emoji" pero los emojis se ven inconsistentes
   entre plataformas. Detectamos el tipo por la primera palabra del texto y
   pintamos un icono SVG coherente. Si no hay match, fallback al icono de check. */
const TRUST_ICONS: Record<string, string> = {
  presupuesto: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
  multimarca: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  llamamos:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  coche:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>`,
  cortesia:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>`,
  pre:         `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  itv:         `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  garantia:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="m15.5 12.5-1.2 8.4a.5.5 0 0 1-.79.36L12 20l-1.5 1.26a.5.5 0 0 1-.8-.36l-1.2-8.4"/></svg>`,
  rapido:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  honesto:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`,
};
function trustIconFor(text: string): string {
  const t = (text || "").toLowerCase();
  for (const key of Object.keys(TRUST_ICONS)) {
    if (t.includes(key)) return TRUST_ICONS[key];
  }
  return TRUST_ICONS.honesto; // fallback: check
}

/* Mapeo id-de-servicio → SVG inline minimal-stroke estilo Lucide.
   Centralizado aquí para que sea trivial añadir o cambiar iconos. */
const SERVICE_ICONS: Record<string, string> = {
  revision:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  mecanica:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  averias:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  neumaticos: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M22 12h-3M5 12H2M19.07 4.93l-2.12 2.12M7.05 16.95l-2.12 2.12M19.07 19.07l-2.12-2.12M7.05 7.05 4.93 4.93"/></svg>`,
  electronica:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>`,
  itv:        `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
};

/* Mailto y WhatsApp pre-rellenados con la URL del subdominio. */
const mailSubject = `Consulta desde ${city.name} (${city.slug}.${NETWORK.domain})`;
const mailBody = `Hola,

Os escribo desde ${canonical}

[Cuéntanos qué necesitas: marca, modelo, año del coche y el problema o servicio que buscas.]

Gracias,
`;
const mailtoUrl = `mailto:${email}?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;
const waMsg = `Hola, escribo desde ${canonical} y me gustaría pedir cita en ${city.name}.`;
const waUrl = `https://wa.me/${whatsapp}?text=${encodeURIComponent(waMsg)}`;

const allFaqs = [...city.faqLocal, ...FAQ_BASE];

/* ──────────────────────────────────────────────────────────
   Schema.org @graph — paquete completo de entidades:
     - AutoRepair (subtipo de LocalBusiness, más específico)
     - Organization (red padre, conecta los subdominios)
     - BreadcrumbList (CCAA → Provincia → Ciudad)
     - OfferCatalog con Service items
     - WebPage que ata todo
     - FAQPage
   ────────────────────────────────────────────────────────── */
const networkOrgId = `https://www.${NETWORK.domain}/#organization`;
const businessId = `${canonical}#business`;
const webpageId = `${canonical}#webpage`;

const autoRepair = {
  "@type": "AutoRepair",
  "@id": businessId,
  name: t ? t.businessName : `Taller mecánico ${city.name}`,
  alternateName: t ? `${t.businessName} · ${city.name}` : undefined,
  description: city.metaDescription,
  url: canonical,
  telephone: phone,
  email: email,
  address: {
    "@type": "PostalAddress",
    ...(addrStreet ? { streetAddress: addrStreet } : {}),
    ...(addrPostal ? { postalCode: addrPostal } : {}),
    addressLocality: city.name,
    addressRegion: city.province,
    addressCountry: "ES",
  },
  ...(geoLat && geoLng ? { geo: { "@type": "GeoCoordinates", latitude: geoLat, longitude: geoLng } } : {}),
  areaServed: { "@type": "City", name: city.name },
  image: `https://${city.slug}.${NETWORK.domain}${heroImage}`,
  priceRange: "€€",
  currenciesAccepted: "EUR",
  paymentAccepted: "Cash, Credit Card, Bank Transfer",
  availableLanguage: "es-ES",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday"],
      opens: "09:00",
      closes: "13:00",
    },
  ],
  parentOrganization: { "@id": networkOrgId },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: `Servicios del taller en ${city.name}`,
    itemListElement: SERVICES.map((s, idx) => ({
      "@type": "Offer",
      position: idx + 1,
      itemOffered: {
        "@type": "Service",
        name: s.title,
        description: city.servicesOverrides?.[s.id] || s.summary,
        areaServed: { "@type": "City", name: city.name },
        provider: { "@id": businessId },
      },
    })),
  },
  ...(gbpUrl ? { sameAs: [gbpUrl] } : {}),
  ...(city.testimonials && city.testimonials.length > 0
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: (city.testimonials.reduce((s, ti) => s + (ti.rating || 5), 0) / city.testimonials.length).toFixed(1),
          reviewCount: city.testimonials.length,
          bestRating: 5,
          worstRating: 1,
        },
      }
    : {}),
};

const organization = {
  "@type": "Organization",
  "@id": networkOrgId,
  name: NETWORK.brand,
  alternateName: "Red de Talleres",
  url: `https://www.${NETWORK.domain}/`,
  logo: `https://${NETWORK.domain}/favicon.svg`,
  slogan: NETWORK.tagline,
  description: `Red nacional de talleres mecánicos multimarca en España. Presupuesto cerrado y todas las marcas.`,
  areaServed: { "@type": "Country", name: "España" },
};

/**
 * BreadcrumbList simplificado a 2 niveles (Red → Ciudad) porque CCAA y
 * Provincia no tienen URL propia. Google requiere `item` URL en TODOS los
 * elementos excepto opcionalmente el último — un breadcrumb con items
 * intermedios sin URL es rechazado por Rich Results test.
 */
const breadcrumbId = `${canonical}#breadcrumb`;
const breadcrumb = {
  "@type": "BreadcrumbList",
  "@id": breadcrumbId,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: NETWORK.brand,
      item: `https://www.${NETWORK.domain}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: `${city.name} (${city.province})`,
      item: canonical,
    },
  ],
};

const webPage = {
  "@type": "WebPage",
  "@id": webpageId,
  url: canonical,
  name: city.metaTitle,
  description: city.metaDescription,
  inLanguage: "es-ES",
  isPartOf: { "@id": networkOrgId },
  about: { "@id": businessId },
  breadcrumb: { "@id": breadcrumbId },
  primaryImageOfPage: `https://${city.slug}.${NETWORK.domain}${heroImage}`,
};

const faqEntity = {
  "@type": "FAQPage",
  "@id": `${canonical}#faq`,
  mainEntity: allFaqs.map(f => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [autoRepair, organization, webPage, breadcrumb, faqEntity],
};

const introParagraphs = city.introLocal.split("\n\n").filter(Boolean);

/* Initials del primer nombre para el avatar de los testimonios. */
const initial = (name: string) => (name || "").trim().charAt(0).toUpperCase();
---

<Layout title={city.metaTitle} description={city.metaDescription} canonical={canonical} schema={schemaGraph}>

  {/* ─────────────────────── NAV ─────────────────────── */}
  <nav class="nav">
    <div class="container nav-inner">
      <a href="#top" class="nav-brand">
        <span class="nav-brand-mark" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9v9a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V9"/><path d="M22 9 12 3 2 9l10 6Z"/></svg>
        </span>
        <span>
          {t ? t.businessName : NETWORK.brand}
          <span class="nav-brand-city"> · {city.name}</span>
        </span>
      </a>
      <div class="nav-links">
        <a href="#servicios">Servicios</a>
        <a href="#proceso">Proceso</a>
        <a href="#problemas">Problemas</a>
        <a href="#opiniones">Opiniones</a>
        <a href="#zona">Zona</a>
        <a href={`/blog/`}>Blog</a>
        <a href="#faq">FAQ</a>
        <a href="#contacto">Contacto</a>
      </div>
      <a href={`tel:${phone}`} class="nav-cta" aria-label={`Llamar a ${phoneDisplay}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{phoneDisplay}</span>
      </a>
    </div>
  </nav>

  <main id="main">

  {/* ─────────────────────── HERO ─────────────────────── */}
  <header id="top" class="hero">
    <img
      src={heroImage}
      alt={`Taller mecánico en ${city.name}`}
      class="hero-img"
      width="1920"
      height="1080"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="container hero-content">
      <span class="hero-eyebrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Taller mecánico en {city.name}, {city.province}
      </span>
      <h1>Tu taller multimarca en {city.name}, sin sorpresas en la factura.</h1>
      <p class="lead">{city.heroSubtitle}</p>
      <div class="hero-ctas">
        <a href={`tel:${phone}`} class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Llamar al taller
        </a>
        <a href={waUrl} target="_blank" rel="noopener" class="btn btn-whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          WhatsApp
        </a>
        <a href={mailtoUrl} class="btn btn-ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email
        </a>
      </div>
    </div>
  </header>

  {/* ─────────────────────── TRUST STRIP ─────────────────────── */}
  {city.trustChips && city.trustChips.length > 0 && (
    <aside class="trust-strip" aria-label="Garantías del taller">
      <div class="container">
        <ul class="trust-strip-list">
          {city.trustChips.map(t => (
            <li class="trust-chip">
              <span class="trust-chip-icon" aria-hidden="true" set:html={trustIconFor(t.text)} />
              <span class="trust-chip-text">{t.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  )}

  {/* ─────────────────────── SERVICIOS ─────────────────────── */}
  <section id="servicios">
    <div class="container">
      <div class="section-head">
        <span class="section-eyebrow"><span class="num">01</span> Servicios</span>
        <h2>Qué hacemos en {city.name}</h2>
        <p class="section-lead">{city.servicesIntro}</p>
      </div>
      <div class="services-grid">
        {SERVICES.map(s => (
          <article class="service-card">
            <span class="service-icon" set:html={SERVICE_ICONS[s.id] || SERVICE_ICONS.revision} />
            <h3>{s.title}</h3>
            <p>{city.servicesOverrides?.[s.id] || s.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────────── PROCESO ─────────────────────── */}
  {city.processSteps && city.processSteps.length > 0 && (
    <section id="proceso" class="process-section">
      <div class="container">
        <div class="section-head">
          <span class="section-eyebrow"><span class="num">02</span> Cómo trabajamos</span>
          <h2>Sin sorpresas, sin medias palabras.</h2>
          {city.processIntro && <p class="section-lead">{city.processIntro}</p>}
        </div>
        <div class="process-grid">
          {city.processSteps.map((step, i) => (
            <article class="process-step">
              <div class="process-step-num">Paso {String(i + 1).padStart(2, "0")}</div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ─────────────────────── PROBLEMAS COMUNES ─────────────────────── */}
  {city.commonIssues && city.commonIssues.length > 0 && (
    <section id="problemas">
      <div class="container">
        <div class="section-head">
          <span class="section-eyebrow"><span class="num">03</span> Problemas comunes</span>
          <h2>Lo que más vemos en coches de {city.name}</h2>
          {city.commonIssuesIntro && <p class="section-lead">{city.commonIssuesIntro}</p>}
        </div>
        <div class="issues-grid">
          {city.commonIssues.map(issue => (
            <article class="issue-card">
              <span class="issue-card-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </span>
              <div>
                <h3>{issue.title}</h3>
                <p>{issue.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ─────────────────────── POR QUÉ NOSOTROS ─────────────────────── */}
  <section id="porque">
    <div class="container">
      <div class="section-head">
        <span class="section-eyebrow"><span class="num">04</span> Por qué nosotros</span>
        <h2>Por qué somos el taller al que se vuelve.</h2>
      </div>
      <div class="why-grid">
        {city.whyUs.map(w => (
          <div class="why-item">
            <h3>{w.title}</h3>
            <p>{w.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────────── TESTIMONIOS ─────────────────────── */}
  {city.testimonials && city.testimonials.length > 0 && (
    <section id="opiniones" class="testi-section">
      <div class="container">
        <div class="section-head">
          <span class="section-eyebrow"><span class="num">05</span> Opiniones</span>
          <h2>Lo que dicen clientes en {city.name}</h2>
          {city.testimonialsIntro && <p class="section-lead">{city.testimonialsIntro}</p>}
        </div>
        <div class="testi-grid">
          {city.testimonials.map(t => {
            const stars = Math.min(5, Math.max(0, Math.round(t.rating || 5)));
            return (
              <article class="testi-card">
                <span class="testi-quote" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 7H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2v3a2 2 0 0 1-2 2H4v2h1a4 4 0 0 0 4-4V9a2 2 0 0 0 0-2zm12 0h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2v3a2 2 0 0 1-2 2h-1v2h1a4 4 0 0 0 4-4V9a2 2 0 0 0 0-2z"/></svg>
                </span>
                <span class="testi-stars" role="img" aria-label={`${stars} de 5 estrellas`}>
                  {Array.from({ length: stars }).map(() => (
                    <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                </span>
                <p class="testi-body">«{t.body}»</p>
                <div class="testi-meta">
                  <span class="testi-avatar" aria-hidden="true">{initial(t.name)}</span>
                  <div class="testi-author">
                    <strong>{t.name}</strong>
                    <span>
                      {t.neighborhood ? `${t.neighborhood}` : ""}
                      {t.neighborhood && t.car ? " · " : ""}
                      {t.car || ""}
                    </span>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* ─────────────────────── ZONA ─────────────────────── */}
  <section id="zona">
    <div class="container">
      <div class="section-head">
        <span class="section-eyebrow"><span class="num">06</span> Cobertura</span>
        <h2>Atendemos en {city.name} y alrededores</h2>
      </div>
      <p class="zone-text">{city.zoneText}</p>
      {city.zoneNeighborhoods && city.zoneNeighborhoods.length > 0 && (
        <>
          <p class="zone-label">Barrios y municipios cercanos</p>
          <div class="zone-chips">
            {city.zoneNeighborhoods.map(n => <span class="chip">{n}</span>)}
          </div>
        </>
      )}
      {city.zoneAccessRoutes && city.zoneAccessRoutes.length > 0 && (
        <>
          <p class="zone-label">Accesos principales</p>
          <div class="zone-chips">
            {city.zoneAccessRoutes.map(r => <span class="chip chip-route">{r}</span>)}
          </div>
        </>
      )}
    </div>
  </section>

  {/* ─────────────────────── FAQ ─────────────────────── */}
  <section id="faq">
    <div class="container">
      <div class="section-head">
        <span class="section-eyebrow"><span class="num">07</span> Preguntas frecuentes</span>
        <h2>Lo que más nos preguntan</h2>
      </div>
      <ul class="faq-list">
        {allFaqs.map(f => (
          <li class="faq-item">
            <details>
              <summary>
                <span>{f.q}</span>
                <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-body"><p>{f.a}</p></div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ─────────────────────── CONTACTO ─────────────────────── */}
  <section id="contacto" class="contact-section">
    <div class="container">
      <div class="section-head" style="text-align: center; margin-left: auto; margin-right: auto;">
        <span class="section-eyebrow"><span class="num">08</span> Pide cita</span>
        <h2>{city.closingHeadline || `Cuida tu coche en ${city.name}`}</h2>
        <p class="section-lead" style="margin-left: auto; margin-right: auto;">{city.closingCta}</p>
      </div>
      <div class="contact-card">
        <p class="label">Llámanos ahora</p>
        <a href={`tel:${phone}`} class="phone-big">{phoneDisplay}</a>
        <p class="hours">{hours}</p>
        {addrStreet && (
          <p style="margin: 0.85rem 0 0; color: rgba(255,255,255,0.85); font-size: 0.95rem;">
            📍 {addrStreet}{addrPostal ? `, ${addrPostal}` : ""}, {city.name}
          </p>
        )}
        <div class="ctas">
          <a href={`tel:${phone}`} class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Llamar
          </a>
          <a href={waUrl} target="_blank" rel="noopener" class="btn btn-whatsapp">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
            WhatsApp
          </a>
          <a href={mailtoUrl} class="btn btn-ghost">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </a>
        </div>
        <p class="contact-email-note">
          O escríbenos a <a href={mailtoUrl}>{email}</a>.
        </p>
      </div>
    </div>
  </section>

  {/* ─────────────────────── CONTEXTO LOCAL (al final por SEO sin estorbar al CTA) ─────────────────────── */}
  <section id="contexto" class="context-section">
    <div class="container">
      <div class="section-head">
        <span class="section-eyebrow"><span class="num">09</span> Contexto local</span>
        <h2>Por qué un coche en {city.name} no se cuida igual que en cualquier otro sitio</h2>
        <p class="section-lead">Lo que tienes que saber sobre el parque automovilístico, el clima y el uso del coche en {city.name}, {city.province}.</p>
      </div>
      <div class="intro-local">
        {introParagraphs.map(p => (<p>{p}</p>))}
      </div>
      <div class="context-meta">
        <div class="context-meta-item">
          <span class="context-meta-label">Ciudad</span>
          <span class="context-meta-value">{city.name}</span>
        </div>
        <div class="context-meta-item">
          <span class="context-meta-label">Provincia</span>
          <span class="context-meta-value">{city.province}</span>
        </div>
        <div class="context-meta-item">
          <span class="context-meta-label">Comunidad</span>
          <span class="context-meta-value">{city.ccaa}</span>
        </div>
        {city.population && (
          <div class="context-meta-item">
            <span class="context-meta-label">Habitantes</span>
            <span class="context-meta-value">{city.population.toLocaleString("es-ES")}</span>
          </div>
        )}
      </div>
    </div>
  </section>

  {/* ─────────────────────── BLOG (últimos artículos) ─────────────────────── */}
  {latestPosts.length > 0 && (
    <section id="blog-preview" class="section-pad section-alt">
      <div class="container">
        <header class="section-head">
          <span class="eyebrow">Consejos para tu coche</span>
          <h2>Últimos artículos del blog</h2>
          <p>Guías prácticas redactadas por nuestro equipo para conductores de {city.name}.</p>
        </header>
        <ul class="blog-preview-list">
          {latestPosts.map((p) => (
            <li>
              <a href={_postUrl(p.id)} class="blog-card">
                {p.data.image && (
                  <img src={p.data.image} alt={p.data.title} loading="lazy" width="600" height="338" class="blog-card-img" />
                )}
                <div class="blog-card-body">
                  <span class="blog-card-cat">{p.data.category}</span>
                  <h3>{p.data.title}</h3>
                  <p class="blog-card-meta">
                    <time datetime={p.data.publishDate.toISOString()}>{_fmtDate(p.data.publishDate)}</time>
                    <span>· {p.data.readTime} min</span>
                  </p>
                  <p class="blog-card-excerpt">{p.data.excerpt}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <p class="blog-preview-cta">
          <a href={`/blog/`} class="btn btn-ghost">Ver todos los artículos →</a>
        </p>
      </div>

      <style>
        .blog-preview-list { list-style: none; padding: 0; display: grid; gap: 1.5rem; }
        @media (min-width: 768px) { .blog-preview-list { grid-template-columns: repeat(3, 1fr); } }
        .blog-card {
          display: block; height: 100%;
          background: var(--surface); color: inherit; text-decoration: none;
          border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;
          transition: box-shadow .2s, transform .2s;
        }
        .blog-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
        .blog-card-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
        .blog-card-body { padding: 1rem 1.25rem 1.25rem; }
        .blog-card-cat {
          display: inline-block; background: var(--amber-100); color: var(--amber-800);
          padding: 0.125rem 0.625rem; border-radius: 999px; font-weight: 600; font-size: 0.75rem;
          margin-bottom: 0.5rem;
        }
        .blog-card h3 { font-size: 1.1rem; margin: 0 0 0.25rem; line-height: 1.35; }
        .blog-card-meta { color: var(--muted); font-size: 0.8125rem; display: flex; gap: 0.5rem; margin: 0 0 0.5rem; }
        .blog-card-excerpt { color: var(--muted); font-size: 0.92rem; line-height: 1.5; margin: 0; }
        .blog-preview-cta { text-align: center; margin-top: 1.5rem; }
      </style>
    </section>
  )}

  </main>

  {/* ─────────────────────── FOOTER ─────────────────────── */}
  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col footer-brand-block">
          <div class="brand-name">{businessName}</div>
          <p>Taller mecánico multimarca {t ? "" : `de la red ${NETWORK.brand}`}. Trabajamos con todas las marcas y damos presupuesto cerrado antes de tocar nada.</p>
          {addrStreet && (
            <p style="font-size: 0.92rem; color: rgba(255,255,255,0.75); margin-bottom: 0.4rem;">
              {addrStreet}{addrPostal ? `, ${addrPostal}` : ""}
            </p>
          )}
          <p style="font-size: 0.85rem; color: rgba(255,255,255,0.45);">{city.name}, {city.province}, {city.ccaa} · España</p>
          {gbpUrl && (
            <p style="margin-top: 0.75rem;">
              <a href={gbpUrl} target="_blank" rel="noopener" style="color: var(--amber-400); font-weight: 600; font-size: 0.88rem;">
                Ver en Google Maps →
              </a>
            </p>
          )}
        </div>
        <div class="footer-col">
          <h2 class="footer-col-title">Servicios</h2>
          <ul>
            {SERVICES.map(s => <li><a href="#servicios">{s.title}</a></li>)}
          </ul>
        </div>
        <div class="footer-col">
          <h2 class="footer-col-title">Contacto</h2>
          <ul>
            <li><a href={`tel:${phone}`}>{phoneDisplay}</a></li>
            <li><a href={waUrl} target="_blank" rel="noopener">WhatsApp</a></li>
            <li><a href={mailtoUrl}>{email}</a></li>
            <li><a href={`/blog/`}>Blog</a></li>
            <li style="margin-top: 0.75rem; color: rgba(255,255,255,0.45);">Lun–Sáb · 08:00–20:00</li>
          </ul>
        </div>
      </div>
      <div class="footer-legal">
        <span>© {new Date().getFullYear()} {NETWORK.brand}. Hecho en {city.name}.</span>
        <div class="footer-legal-links">
          <a href="https://www.redtalleres.es/">Red completa</a>
          <a href="/aviso-legal/">Aviso legal</a>
          <a href="/privacidad/">Privacidad</a>
        </div>
      </div>
    </div>
  </footer>

  {/* ─────────────────────── FLOAT CTA MOBILE ─────────────────────── */}
  <div class="float-cta">
    <a href={`tel:${phone}`} class="btn btn-primary" aria-label="Llamar al taller">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Llamar
    </a>
    <a href={waUrl} target="_blank" rel="noopener" class="btn btn-whatsapp" aria-label="Abrir WhatsApp">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
      WhatsApp
    </a>
  </div>
</Layout>


